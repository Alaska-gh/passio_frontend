rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn()  { return request.auth != null; }
    function uid()         { return request.auth.uid; }
     function userDoc()     { return exists(/databases/$(database)/documents/users/$(uid())) ?
      get(/databases/$(database)/documents/users/$(uid())).data : null; 
    }
    function role()        { return isSignedIn() && userDoc() != null ? userDoc().role : null; }
    function isAdmin()     { return role() == 'admin'; }
    function isDriver()    { return role() == 'driver'; }
    function isConductor() { return role() == 'conductor'; }
    function isCashier() { return role() == 'cashier'; }
    function isOwner(userId) { return isSignedIn() && uid() == userId; }

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'customer';
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /busses/{busId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
      allow update: if isAdmin() || isDriver() || isCashier()
    }

    match /routes/{routeId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    match /tickets/{ticketId} {
      allow read:   if isOwner(resource.data.customerId) || isAdmin() || isConductor() || isCashier();
      allow create: if isCashier() || isAdmin();
      allow update: if isAdmin() || isCashier();
      allow delete: if false;
    }

  match /trips/{tripId} {
    allow read: if isSignedIn();

    allow create: if isAdmin() || isCashier();
    allow update: if isAdmin() || isCashier();
    allow delete: if false;
  }

   match /loadingSystem/{docId} {
      allow read:   if isAdmin() || isCashier();
      allow update: if isAdmin() || isCashier(); // rotation on ticket issue
      allow create: if isAdmin();                // only admin sets up initial config
      allow delete: if false;
    }

    match /queue/{docId} {
      allow read, write: if false;
    }

    match /payments/{paymentId} {
      allow read:                   if isOwner(resource.data.customerId) || isAdmin();
      allow create, update, delete: if false;
    }

    match /auditLog/{logId} {
      allow read, write: if false;
    }

    match /busRequests/{requestId} {
      allow read: if isAdmin() || 
        (isDriver() && resource.data.driverId == uid());
      allow create: if isDriver();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}